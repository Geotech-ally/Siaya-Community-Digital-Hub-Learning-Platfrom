# ==========================================================
# Backend environment (NestJS + Prisma). Copy to .env; never commit .env.
# PM2 deployment on the hub server (system PostgreSQL + Redis on localhost).
# ==========================================================

NODE_ENV=production
PORT=5000

# PostgreSQL on the same box. Create a dedicated DB + user (see deploy/DEPLOY.md).
DATABASE_URL=postgresql://siaya:CHANGE_ME_DB_PASSWORD@localhost:5432/sicodihub_lms?schema=public

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis on the same box (BullMQ queues). Install: sudo apt install redis-server
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Public origin the frontend is served from (used when CORS is locked down)
CORS_ORIGIN=https://learn.example.com

# SMTP (optional). Leave blank to disable email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sicodihub.ac.ke
