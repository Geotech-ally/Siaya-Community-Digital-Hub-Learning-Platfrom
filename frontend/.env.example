# ==========================================================
# Frontend environment (Next.js). Copy to .env; never commit .env.
#
# NEXT_PUBLIC_* is baked into the client bundle at BUILD time. The browser calls
# `${NEXT_PUBLIC_API_URL}/api/v1/...`, so in production this must be the PUBLIC
# api subdomain (the Cloudflare Tunnel routes it to the backend on localhost:5000).
# Because it's build-time, changing it requires rebuilding (`npm run build`).
# ==========================================================

# Local dev:    http://localhost:5000
# Production:   https://api.learn.example.com   (the api subdomain, no trailing slash)
NEXT_PUBLIC_API_URL=https://api.learn.example.com
